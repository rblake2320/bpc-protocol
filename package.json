{
  "name": "bpc-protocol",
  "version": "0.2.0",
  "private": true,
  "description": "BPC — Bound Pair Credentials: pair-authorized, signed, replay-resistant API request protocol",
  "workspaces": [
    "packages/core",
    "packages/server",
    "packages/client-sdk"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "node --test tests/workspace-test-runner.test.mjs && node scripts/run-workspace-tests.mjs",
    "test:redis": "tsx redis-nonce-integration.mts",
    "test:postgres": "tsx postgres-store-integration.mts",
    "test:postgres:ha": "tsx ha-outbox-pg-integration.mts",
    "test:interop": "tsx cross-language-integration.mts",
    "test:adversarial": "tsx adversarial-integration.mts",
    "test:pack": "npm pack --dry-run --workspaces",
    "test:core": "npm run test --workspace=packages/core",
    "test:server": "npm run test --workspace=packages/server",
    "test:client": "npm run test --workspace=packages/client-sdk"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "ioredis": "^5.4.1",
    "pg": "^8.22.0",
    "tsx": "^4.23.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}

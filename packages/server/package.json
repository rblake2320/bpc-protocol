{
  "name": "@bpc/server",
  "version": "0.2.0",
  "description": "BPC Protocol server-side verification middleware",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck:contract": "tsc --noEmit -p tsconfig.contract-typecheck.json"
  },
  "dependencies": {
    "@bpc/core": "^0.2.0"
  },
  "peerDependencies": {
    "ioredis": ">=5.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "tsx": "^4.23.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
